{
  "info": {
    "name": "Employee API Tests",
    "_postman_id": "emp-api-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    }
  ],
  "item": [

    {
      "name": "GET All Employees",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/employees"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Response is array', () => Array.isArray(pm.response.json()));"
            ]
          }
        }
      ]
    },

    {
      "name": "POST Add Employee",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"employeeId\": \"{{employeeId}}\",\n  \"name\": \"{{name}}\",\n  \"email\": \"{{email}}\",\n  \"department\": \"{{department}}\",\n  \"position\": \"{{position}}\",\n  \"status\": \"{{status}}\"\n}"
        },
        "url": "{{base_url}}/employees/employee"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Employee added', () => pm.response.json().message === 'Employee added successfully');"
            ]
          }
        }
      ]
    },

    {
      "name": "PUT Update Employee",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"employeeId\": \"{{employeeId}}\",\n  \"name\": \"{{name}}\",\n  \"email\": \"{{email}}\",\n  \"department\": \"{{department}}\",\n  \"position\": \"Senior Tester\",\n  \"status\": \"{{status}}\"\n}"
        },
        "url": "{{base_url}}/employees/{{employeeId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Updated successfully', () => pm.response.json().message === 'Employee updated successfully');"
            ]
          }
        }
      ]
    },

    {
      "name": "GET Employee By ID",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/employees/{{employeeId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Correct employee', () => pm.response.json().employeeId === pm.variables.get('employeeId'));"
            ]
          }
        }
      ]
    },

    {
      "name": "GET By Department",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/employees/department/{{department}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));"
            ]
          }
        }
      ]
    },

    {
      "name": "DELETE Employee",
      "request": {
        "method": "DELETE",
        "url": "{{base_url}}/employees/{{employeeId}}"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Deleted successfully', () => pm.response.json().message === 'Employee deleted successfully');"
            ]
          }
        }
      ]
    }

  ]
}